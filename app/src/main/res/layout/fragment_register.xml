<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:clickable="true"
        android:fillViewport="true"
        android:focusable="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/sixteen_dp"
                    android:layout_marginTop="@dimen/_25sdp"
                    android:fontFamily="@font/poppins"
                    android:gravity="center"
                    android:text="@string/sign_up"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_28sdp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/llr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_16sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/tvWelcome">

                    <FrameLayout
                        android:id="@+id/frImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/profile_image"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pandit_ji_img"
                            app:shapeAppearanceOverlay="@style/CircularImageView" />

                        <ImageView
                            android:id="@+id/camera_icon"
                            android:layout_width="@dimen/fourty_dp"
                            android:layout_height="@dimen/fourty_dp"
                            android:layout_gravity="bottom|end"
                            android:padding="3dp"
                            android:src="@drawable/edit_pen_icon" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/label_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/twenty_dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/first_name_"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <EditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"

                        android:hint="@string/enter_your_first_name"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/last_name_"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <EditText
                        android:id="@+id/et_last_name"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/enter_your_last_name"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:id="@+id/label_phone_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/phone_number_"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintBottom_toTopOf="@id/et_phone_number"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/et_email" />

                    <EditText
                        android:id="@+id/et_phone_number"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/enter_phone_number"
                        android:inputType="phone"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_phone_number" />


                    <!-- Email Label -->
                    <TextView
                        android:id="@+id/label_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/email_"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintBottom_toTopOf="@id/et_email"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/et_name" />

                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/enter_your_email_address"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_email" />

                    <TextView
                        android:id="@+id/label_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/password_"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintBottom_toTopOf="@id/et_email"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/et_email" />

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/enter_your_password"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_password" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"

                        android:fontFamily="@font/roboto_regular"
                        android:text="@string/dob"
                        android:textColor="#3C3C3C"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clSelectDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:paddingVertical="15dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/llr">

                        <TextView
                            android:id="@+id/et_dob"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/ten"
                            android:fontFamily="@font/inter_semibold"
                            android:text="@string/select_date_of_birth"
                            android:textColor="@color/black"
                            android:textSize="@dimen/sixteen_sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/gotra"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <EditText
                        android:id="@+id/et_Gotra"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/enter_your_gotra"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView

                        android:id="@+id/label_prawar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/roboto_regular"
                        android:text="@string/prawar"
                        android:textColor="#3C3C3C"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toTopOf="@id/et_email"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/et_name" />

                    <EditText

                        android:id="@+id/et_Prawar"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_prawar"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_email" />

                    <TextView


                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/veda"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <EditText
                        android:id="@+id/etVeda"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_veda"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView


                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/roboto_regular"
                        android:text="@string/shakha"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <EditText
                        android:id="@+id/etShakha"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_shakha"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView


                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/pankti"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <EditText
                        android:id="@+id/etPankti"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_pankti"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView


                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/sutra"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <EditText
                        android:id="@+id/etSutra"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_sutra"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/aadhar_number"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etAadharNumber"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_aadhar_number"
                        android:inputType="textPersonName"
                        android:maxLength="12"
                        android:maxLines="1"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/select_service"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <TextView
                        android:id="@+id/etServices"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:gravity="start|center"
                        android:hint="@string/select_service"
                        android:inputType="textPersonName"
                        android:padding="10dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/select_language"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/frImage" />

                    <TextView
                        android:id="@+id/etLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:gravity="start|center"
                        android:hint="@string/select_language"
                        android:inputType="textPersonName"
                        android:padding="10dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/total_experience"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/etExperience"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_total_experience"
                        android:inputType="number"
                        android:maxLines="5"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/about"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <EditText
                        android:id="@+id/et_About"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_outline"
                        android:fontFamily="@font/poppins"
                        android:hint="@string/enter_about"
                        android:maxLines="5"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="15dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintTop_toBottomOf="@id/label_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/address_landmark"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_address"
                        android:inputType="text"
                        android:maxLines="5"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/state"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_your_state"
                        android:inputType="text"
                        android:maxLines="5"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/city"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_your_city"
                        android:inputType="text"
                        android:maxLines="5"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/pincode"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/pincode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_your_pincode"
                        android:inputType="number"
                        android:maxLines="5"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/country"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/country"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_your_country"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fifteen"
                        android:fontFamily="@font/inter"
                        android:text="@string/referral_code"
                        android:textColor="@color/black"
                        android:textSize="14sp" />


                    <EditText
                        android:id="@+id/referral_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/five_dp"
                        android:background="@drawable/grey_bg_box_radi_16dp"
                        android:fontFamily="@font/inter_semibold"
                        android:hint="@string/enter_your_referral_code"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="15dp"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintStart_toStartOf="parent" />

                </LinearLayout>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_margin="@dimen/sixteen_dp"
                    android:layout_marginTop="@dimen/fifteen"
                    android:backgroundTint="@color/app_color_second"
                    android:fontFamily="@font/roboto_regular"
                    android:text="@string/sign_up"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sixteen_sp"
                    app:cornerRadius="@dimen/five_dp"
                    app:iconGravity="textEnd"
                    app:iconPadding="@dimen/ten"
                    app:iconSize="@dimen/fifteen"
                    app:iconTint="@color/white"
                    app:layout_constraintTop_toBottomOf="@id/llr" />

                <TextView
                    android:id="@+id/tvAlreadyHaveAccount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/sixteen_dp"
                    android:layout_marginTop="@dimen/fifteen"
                    android:fontFamily="@font/roboto_regular"
                    android:gravity="center"
                    android:text="@string/already_have_an_account_login"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSignUp" />

                <ImageView
                    android:id="@+id/ivOr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/twenty_dp"
                    android:src="@drawable/ic_or"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAlreadyHaveAccount" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/google"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/sixteen_dp"
                    android:layout_marginTop="@dimen/twenty_dp"
                    android:background="@drawable/grey_outline"
                    android:elevation="@dimen/ten"
                    android:paddingVertical="@dimen/fifteen"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/ivOr">

                    <ImageView
                        android:id="@+id/ivGoogle"
                        android:layout_width="@dimen/twenty_four_dp"
                        android:layout_height="@dimen/twenty_four_dp"
                        android:layout_marginEnd="@dimen/ten"
                        android:src="@drawable/google"
                        app:layout_constraintBottom_toBottomOf="@id/tvGoogle"
                        app:layout_constraintEnd_toStartOf="@id/tvGoogle"
                        app:layout_constraintTop_toTopOf="@id/ivGoogle" />

                    <TextView
                        android:id="@+id/tvGoogle"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/roboto_regular"
                        android:text="Connect With Google"
                        android:textColor="@color/black"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/iVApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/sixteen_dp"
                    android:layout_marginTop="@dimen/twenty_dp"
                    android:background="@drawable/grey_outline"
                    android:elevation="@dimen/ten"
                    android:paddingVertical="@dimen/fifteen"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/google">

                    <ImageView
                        android:id="@+id/ivApple"
                        android:layout_width="@dimen/twenty_four_dp"
                        android:layout_height="@dimen/twenty_four_dp"
                        android:layout_marginEnd="@dimen/ten"
                        android:src="@drawable/google"
                        app:layout_constraintBottom_toBottomOf="@id/tvApple"
                        app:layout_constraintEnd_toStartOf="@id/tvApple"
                        app:layout_constraintTop_toTopOf="@id/ivApple" />

                    <TextView
                        android:id="@+id/tvApple"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/roboto_regular"
                        android:text="Connect With Apple"
                        android:textColor="@color/black"
                        android:textSize="@dimen/sixteen_sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginVertical="@dimen/twenty_dp"
                    app:layout_constraintTop_toBottomOf="@id/iVApp" />


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </ScrollView>
</layout>