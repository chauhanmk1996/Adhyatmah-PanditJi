<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- <ScrollView
         android:layout_width="match_parent"
         android:layout_height="match_parent"
         android:fillViewport="true">-->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:clickable="true"
        android:fillViewport="true"
        android:focusable="true">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            tools:context=".presentation.ui.login.LoginFragment">
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/oneThirdGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.1" />
            <TextView
                android:id="@+id/loginText"
                android:layout_width="wrap_content"
                android:text="@string/sign_in"
                app:layout_constraintTop_toBottomOf="@+id/oneThirdGuide"
                android:fontFamily="@font/roboto_regular"
                android:textColor="@color/black"
                android:textSize="35dp"
                android:textFontWeight="400"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:visibility="visible"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@+id/loginText"
                tools:layout_editor_absoluteX="16dp">

                <com.hbb20.CountryCodePicker
                    android:visibility="gone"
                    android:id="@+id/countryPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:shadowColor="@color/white"
                    app:ccpDialog_backgroundColor="@color/white"
                    app:ccp_showFullName="false"
                    app:ccp_showFlag="false"
                    app:ccp_showNameCode="false"
                    app:ccp_autoDetectCountry="true"
                    app:ccp_defaultNameCode="IN" />
                <View
                    android:visibility="gone"
                    android:layout_width="1dp"
                    app:layout_constraintStart_toEndOf="@+id/countryPicker"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:background="@color/white"
                    android:layout_height="30dp"/>

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/text_input"
                    android:fontFamily="@font/roboto_regular"
                    android:textSize="15dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginTop="10sp"
                    app:layout_constraintStart_toStartOf="parent"
                    android:text="@string/email"
                    android:textFontWeight="400"
                    app:layout_constraintBottom_toTopOf="@+id/phonenumberInput"
                    android:layout_height="wrap_content"/>

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/phonenumberInput"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:gravity="center_vertical"
                    android:hint="@string/email_id"
                    android:paddingStart="10dp"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:background="@drawable/grey_outline"
                    android:textColor="@color/black"
                    android:textColorHint="@color/text_input"
                    android:textSize="16sp"
                    android:visibility="visible"
                    app:ccp_showFullName="false"
                    app:layout_constraintBottom_toTopOf="@+id/textView2"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/countryPicker"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="match_parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/text_input"
                    android:fontFamily="@font/roboto_regular"
                    android:textSize="15dp"
                    android:layout_marginBottom="5dp"
                    app:layout_constraintStart_toStartOf="parent"
                    android:text="@string/password"
                    android:textFontWeight="400"
                    app:layout_constraintBottom_toTopOf="@+id/passwordContainer"
                    android:layout_height="wrap_content"/>


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/passwordContainer"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    app:layout_constraintStart_toEndOf="@id/countryPicker"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/passInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="@string/password"
                        android:paddingStart="10dp"
                        android:paddingEnd="40dp"
                        android:gravity="center_vertical"
                        android:inputType="textPassword"
                        android:background="@drawable/grey_outline"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_input"
                        android:textSize="16sp"/>

                    <ImageView
                        android:id="@+id/togglePasswordVisibility"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Toggle Password Visibility"
                        android:src="@drawable/eye_on"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/fogot_pass"
                    android:layout_width="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/black"
                    android:fontFamily="@font/roboto_regular"
                    android:textSize="16dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/forgot_your_password"
                    android:gravity="end"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@+id/passwordContainer"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textFontWeight="400"
                    android:layout_height="wrap_content"/>


            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:visibility="gone"
                android:id="@+id/term"
                android:layout_width="match_parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="24dp"
                android:textColor="@color/text_input"
                android:fontFamily="@font/roboto_regular"
                android:textSize="14dp"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:text="By signing up you agree to our Terms of Services and Privacy Policy."
                app:layout_constraintTop_toBottomOf="@+id/layoutInput"
                android:layout_height="wrap_content"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="@dimen/sixteen_dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_color_second"
                android:fontFamily="@font/roboto_regular"
                android:text="@string/sign_in"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/sixteen_sp"
                app:cornerRadius="@dimen/five_dp"
                app:iconGravity="textEnd"
                app:iconPadding="@dimen/ten"
                app:iconSize="@dimen/fifteen"
                app:iconTint="@color/white"
                app:layout_constraintTop_toBottomOf="@id/term"
                tools:layout_editor_absoluteX="16dp" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="20dp"
                android:id="@+id/orLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/loginBtn">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:background="@color/white_E3E3E3"/>
                <TextView
                    android:paddingHorizontal="5dp"
                    android:id="@+id/orText"
                    android:background="@color/white"
                    android:layout_width="wrap_content"
                    android:textColor="@color/text_input"
                    android:fontFamily="@font/roboto_regular"
                    android:textSize="15dp"
                    android:layout_marginBottom="5dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:text="@string/or_"

                    android:layout_height="wrap_content"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logiWithOtp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="@dimen/sixteen_dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_color_second"
                android:fontFamily="@font/roboto_regular"
                android:text="@string/sign_in_using_otp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/sixteen_sp"
                app:cornerRadius="@dimen/five_dp"
                app:iconGravity="textEnd"
                app:iconPadding="@dimen/ten"
                app:iconSize="@dimen/fifteen"
                app:iconTint="@color/white"
                app:layout_constraintTop_toBottomOf="@id/orLayout"
                tools:layout_editor_absoluteX="16dp" />

            <LinearLayout
                android:layout_marginTop="20dp"
                android:paddingBottom="20dp"
                android:id="@+id/bottomLayoutId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/logiWithOtp"
                android:weightSum="2"
                android:layout_marginBottom="90dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/alreadyHaveAccountId"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:fontFamily="@font/roboto_regular"
                    android:gravity="center"
                    android:text="@string/don_t_have_an_account"
                    android:textColor="@color/black"
                    android:textFontWeight="400"
                    android:textSize="16sp"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/loginPage"
                    android:layout_marginStart="5dp"
                    android:layout_width="wrap_content"
                    android:textColor="@color/black"
                    android:fontFamily="@font/roboto_bold"
                    android:textSize="16sp"
                    android:visibility="gone"
                    android:text="Sign up"
                    android:textFontWeight="400"
                    android:layout_height="wrap_content"
                    tools:ignore="MissingConstraints" />


            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>
</layout>