<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="13dp"
        android:background="@drawable/rectangle_background_white_strock_2">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter_bold"
            android:layout_marginTop="23dp"
            android:paddingBottom="23dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="5dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_height="wrap_content"
            android:text="AC &amp; Appliance Repair"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/video_button" />
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_marginEnd="10dp"
            android:id="@+id/video_button"
            app:layout_constraintStart_toEndOf="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:visibility="gone"
            android:src="@drawable/bag_icon"
            app:layout_constraintEnd_toStartOf="@+id/expand_button"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/view"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_marginEnd="10dp"
            android:id="@+id/expand_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/home"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/view"/>

        <View
            android:layout_marginHorizontal="10dp"
            android:id="@+id/view"
            app:layout_constraintTop_toBottomOf="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black" />

        <androidx.appcompat.widget.AppCompatTextView
            android:lineSpacingMultiplier="1.3"
            app:layout_constraintTop_toBottomOf="@id/view"
            android:id="@+id/description"
            android:layout_width="0dp"
            android:textColor="@color/black"
            android:fontFamily="@font/inter"
            android:layout_marginVertical="10dp"
            android:layout_marginHorizontal="10dp"
            android:layout_height="wrap_content"
            android:text="Lorem Ipsum is simply dummy text of the printing and typesetting industry. printing and typesetting industry."
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>